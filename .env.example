# =====================================================
# Bybit Trading Bot Configuration
# =====================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =====================================================

# --- REQUIRED: Bybit API credentials ---
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here

# --- REQUIRED: Risk management ---
# 1R in USD — how much you risk per trade in dollars.
# Example: if RISK_PER_TRADE_USD=100, then each trade
# risks exactly $100 (position size auto-calculated).
RISK_PER_TRADE_USD=100

# --- Bybit connection ---
# Set to true to use Bybit testnet (recommended for testing!)
BYBIT_TESTNET=false
SYMBOL=XAUUSD
CATEGORY=linear
TIMEFRAME=60

# --- Strategy parameters ---
RR_RATIO=2.0
SL_BUFFER_PCT=0.001
MAX_SL_POINTS=15.0
MIN_SL_POINTS=2.0
MIN_SWEEP_WICK_PCT=0.0003

# --- Session sweep toggles ---
TRADE_ASIAN_SWEEP_IN_LONDON=true
TRADE_ASIAN_SWEEP_IN_NY=true
TRADE_LONDON_SWEEP_IN_NY=true
TRADE_PDH_SWEEP=true
TRADE_PDL_SWEEP=true

# --- Filters ---
USE_SESSION_SL=true
ONLY_FIRST_SWEEP=true
REQUIRE_PDL_PDH_CONFLUENCE=false
CONFLUENCE_DISTANCE_PCT=0.003
NO_TRADE_FRIDAY_AFTER=18

# --- Bot behaviour ---
POLL_INTERVAL_SEC=60
LOOKBACK_BARS=200
MAX_OPEN_POSITIONS=1

# --- Logging ---
LOG_LEVEL=INFO
